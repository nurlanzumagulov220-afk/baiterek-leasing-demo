# Скопируйте в .env и заполните перед запуском

# Обязательно поменяйте в production!
JWT_SECRET=change-me-in-production

# Первый администратор (создаётся автоматически при старте)
ADMIN_EMAIL=admin@baiterek.kz
ADMIN_PASSWORD=change-me-in-production

# URL сервиса Aksakal (Go)
AKSAKAL_URL=http://localhost:8080

# БД: SQLite (дефолт для разработки) или PostgreSQL (production)
DATABASE_URL=sqlite:///./baiterek.db
# DATABASE_URL=postgresql://user:password@host:5432/baiterek

# Базовый URL для QR-кодов в PDF-договорах (Execution Oracle)
VERIFY_BASE_URL=http://localhost:8000
# VERIFY_BASE_URL=https://api.qumyrsqa.kz

# CORS: домены фронтенда через запятую
# В production замените * на конкретные домены!
CORS_ORIGINS=*
# CORS_ORIGINS=https://baiterek.kz,https://www.baiterek.kz
