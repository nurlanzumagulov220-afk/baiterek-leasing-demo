{
  "atom_id": "leasing_wagons_s1",
  "version": "1.0.0",
  "product_name": "Лизинг вагонов и авиатранспорта — I этап (индустриальный)",
  "category": "leasing",
  "description": "Приобретение вагонов и авиатранспорта в лизинг для субъектов индустриально-инновационной деятельности",
  "logic_math": "annuity",
  "params": {
    "rate_annual_pct": 18.0,
    "min_amount": 5000000,
    "max_amount": 500000000,
    "min_months": 12,
    "max_months": 84,
    "advance_pct_min": 10,
    "advance_pct_max": 49,
    "currency": "KZT"
  },
  "steps": [
    {
      "step": 1,
      "title": "Сведения о заявителе",
      "description": "Введите данные о вашей организации",
      "fields": [
        {
          "id": "bin",
          "label": "БИН организации",
          "type": "text",
          "mask": "############",
          "placeholder": "123456789012",
          "validation": {
            "required": true,
            "length": 12,
            "pattern": "^\\d{12}$"
          },
          "prefill": "egov.bin",
          "hint": "12-значный бизнес-идентификационный номер"
        },
        {
          "id": "company_name",
          "label": "Наименование организации",
          "type": "text",
          "validation": {
            "required": true,
            "min_length": 3
          },
          "prefill": "egov.company_name",
          "placeholder": "ТОО «Название»"
        },
        {
          "id": "director_name",
          "label": "ФИО руководителя",
          "type": "text",
          "validation": {
            "required": true
          }
        },
        {
          "id": "phone",
          "label": "Контактный телефон",
          "type": "text",
          "mask": "+7 (###) ###-##-##",
          "validation": {
            "required": true
          }
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "validation": {
            "required": true,
            "pattern": "^[^@]+@[^@]+\\.[^@]+$"
          }
        },
        {
          "id": "region",
          "label": "Регион",
          "type": "select",
          "options": [
            "Алматы",
            "Астана",
            "Шымкент",
            "Акмолинская",
            "Актюбинская",
            "Алматинская",
            "Атырауская",
            "ВКО",
            "Жамбылская",
            "ЗКО",
            "Карагандинская",
            "Костанайская",
            "Кызылординская",
            "Мангистауская",
            "Павлодарская",
            "СКО",
            "Туркестанская",
            "Улытауская",
            "Абайская",
            "Жетысуская"
          ],
          "validation": {
            "required": true
          }
        }
      ]
    },
    {
      "step": 2,
      "title": "Параметры лизинга",
      "description": "Укажите параметры финансирования",
      "fields": [
        {
          "id": "equipment_type",
          "label": "Вид оборудования",
          "type": "select",
          "options": [
            "Вагоны грузовые",
            "Вагоны пассажирские",
            "Авиатранспорт",
            "Спецтехника"
          ],
          "validation": {
            "required": true
          }
        },
        {
          "id": "equipment_count",
          "label": "Количество единиц",
          "type": "number",
          "validation": {
            "required": true,
            "min": 1
          }
        },
        {
          "id": "equipment_cost",
          "label": "Стоимость оборудования (тенге)",
          "type": "number",
          "mask": "number",
          "validation": {
            "required": true,
            "min": 5000000,
            "max": 500000000
          },
          "hint": "От 5 000 000 до 500 000 000 тенге"
        },
        {
          "id": "advance_pct",
          "label": "Размер аванса (%)",
          "type": "number",
          "validation": {
            "required": true,
            "min": 10,
            "max": 49
          },
          "hint": "От 10% до 49% от стоимости"
        },
        {
          "id": "term_months",
          "label": "Срок лизинга (месяцев)",
          "type": "select",
          "options": [
            12,
            24,
            36,
            48,
            60,
            72,
            84
          ],
          "validation": {
            "required": true
          }
        },
        {
          "id": "advance_amount",
          "label": "Сумма аванса (тенге)",
          "type": "calculated",
          "formula": "equipment_cost * advance_pct / 100",
          "readonly": true,
          "format": "currency"
        },
        {
          "id": "principal",
          "label": "Сумма финансирования (тенге)",
          "type": "calculated",
          "formula": "equipment_cost - advance_amount",
          "readonly": true,
          "format": "currency"
        },
        {
          "id": "monthly_payment",
          "label": "Ежемесячный платёж (тенге)",
          "type": "calculated",
          "formula": "annuity(principal, params.rate_annual_pct, term_months)",
          "readonly": true,
          "format": "currency",
          "highlight": true
        },
        {
          "id": "total_payment",
          "label": "Общая сумма выплат (тенге)",
          "type": "calculated",
          "formula": "monthly_payment * term_months",
          "readonly": true,
          "format": "currency"
        }
      ]
    },
    {
      "step": 3,
      "title": "Документы",
      "description": "Прикрепите необходимые документы",
      "fields": [
        {
          "id": "business_plan",
          "label": "Бизнес-план",
          "type": "file",
          "accept": ".pdf,.doc,.docx",
          "validation": {
            "required": false
          },
          "hint": "Формат PDF или Word, до 10 МБ"
        },
        {
          "id": "financial_report",
          "label": "Финансовая отчётность за последний год",
          "type": "file",
          "accept": ".pdf,.xlsx,.xls",
          "validation": {
            "required": false
          }
        },
        {
          "id": "equipment_invoice",
          "label": "Счёт-фактура / коммерческое предложение на оборудование",
          "type": "file",
          "accept": ".pdf",
          "validation": {
            "required": false
          }
        },
        {
          "id": "additional_docs",
          "label": "Дополнительные документы (если есть)",
          "type": "file",
          "accept": ".pdf,.doc,.docx,.jpg,.png",
          "validation": {
            "required": false
          },
          "multiple": true
        }
      ]
    },
    {
      "step": 4,
      "title": "Подтверждение",
      "description": "Проверьте данные перед отправкой",
      "fields": [
        {
          "id": "consent_personal_data",
          "label": "Согласен на обработку персональных данных",
          "type": "checkbox",
          "validation": {
            "required": true
          }
        },
        {
          "id": "consent_accuracy",
          "label": "Подтверждаю достоверность предоставленных сведений",
          "type": "checkbox",
          "validation": {
            "required": true
          }
        }
      ]
    }
  ],
  "atom_tamga_id": "126badb9e9d173098470b95167c8b718d52c9d3409586a790cee787a4781f8c6"
}